{
  "TextToBbox": {
    "tool": "TextToBbox",
    "purpose": "在遥感图像中定位指定地物，输出像素坐标边界框。",
    "inputs": {
      "image": "图像路径（本地）",
      "text": "地物类型/描述（如建筑物/道路/水体/船舶/飞机等）",
      "top1": "是否仅返回置信度最高目标"
    },
    "outputs": {
      "bbox_px": "(x1, y1, x2, y2) 像素坐标",
      "score": "检测置信度"
    },
    "unit_rules": [
      "所有边界框为像素单位",
      "面积/距离需结合GSD换算：area_m2=(x2-x1)*(y2-y1)*GSD^2"
    ],
    "examples": [
      {
        "input": {
          "image": "data/rs/scene_01.png",
          "text": "???",
          "top1": true
        },
        "output": {
          "bbox_px": [
            120,
            80,
            260,
            190
          ],
          "score": 0.92
        }
      }
    ],
    "validation": {
      "input_rules": [
        "????????????????????????",
        "bbox???[x1,y1,x2,y2]?x1<x2,y1<y2",
        "???????px???",
        "bbox???????????"
      ],
      "output_rules": [
        "?????/???????????(m?m2)",
        "???GSD??????GSD??(??/??/??)"
      ],
      "assumptions": [
        "???????????????",
        "????????????"
      ],
      "error_tolerance": {
        "bbox_iou": 0.5,
        "count_abs": 1,
        "area_rel": 0.1,
        "distance_rel": 0.1
      }
    }
  },
