  "DrawMask": {
    "tool": "DrawMask",
    "purpose": "Overlay a segmentation mask or polygon on the image for visualization.",
    "inputs": {
      "image": "image path (local)",
      "mask_path": "optional: path to a mask image (grayscale or binary)",
      "polygon": "optional: list of [x,y] polygon points",
      "bbox": "optional: fallback rectangle (x1,y1,x2,y2)",
      "color": "overlay color (e.g., red)",
      "alpha": "overlay opacity in [0,1]"
    },
    "outputs": {
      "image_path": "output image path"
    },
    "unit_rules": [
      "bbox is in pixel coordinates",
      "mask and image should have same size (mask will be resized if needed)"
    ],
    "examples": [
      {
        "input": {
          "image": "data/rs/scene_08.png",
          "bbox": [
            120,
            80,
            260,
            190
          ],
          "color": "red",
          "alpha": 0.4
        },
        "output": {
          "image_path": "outputs/scene_08_mask.png"
        }
      }
    ]
  },
